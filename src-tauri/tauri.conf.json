{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "t3lang",
  "version": "3.0.0",
  "identifier": "de.fullhaus.t3lang",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "t3lang",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "trafficLightPosition": { "x": 19, "y": 26 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BreathCodeFlow/t3lang/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0QjkwODQxQUJEQUE4NjIKUldSaXFOcXJRUWk1WkJkTUNzMXlVY2ViVjVIUmdrRFZLNTg3L0VQL0ZYeHFMQVJ5K2xLbWtJVkoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "shortDescription": "TYPO3 XLIFF translation manager",
    "longDescription": "Manage TYPO3 XLIFF translations: open whole projects, add/reorder entries, manage every language, and switch between XLIFF 1.2 and 2.0.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
